# Sandcastle autonomous issue loop — copy to .sandcastle/.env and fill in values.
# Do not commit .sandcastle/.env (see root .gitignore).

# =============================================================================
# Cursor Agent CLI
# =============================================================================
# Host-mode Sandcastle reuses `agent login` on the host.
# Optional override if `agent` is not on PATH:
# CURSOR_AGENT_BIN=/path/to/agent
# Optional API key instead of login:
# CURSOR_API_KEY=<your-cursor-api-key>

CURSOR_MODEL=auto
# CURSOR_REVIEW_MODEL=auto

# =============================================================================
# Sandcastle workflow
# =============================================================================
# Optional: force a feature branch for accumulated RALPH commits.
# Default: stay on your current git branch.
# SANDCASTLE_BRANCH=feat/my-epic

# GitHub issue label the implementer picks up (default: Sandcastle)
# SANDCASTLE_ISSUE_LABEL=Sandcastle

# Skip the review phase (default: false)
# SKIP_SANDCASTLE_REVIEW=false

# Run Sandcastle inside Docker (set via npm script; rarely needed in .env)
# SANDCASTLE_USE_DOCKER=false

# =============================================================================
# GitHub
# =============================================================================
# Fine-grained token: https://github.com/settings/personal-access-tokens/new
# Required repository permissions: Issues (Read and write) and Metadata (Read)
GH_TOKEN=<your-github-fine-grained-token>
