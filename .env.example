# AgentGate local environment
# Copy to .env and fill in values. Do not commit .env (see .gitignore).
# Loaded by `uv run agentgate ...`, FastAPI dashboard, and release-check CLI.

# =============================================================================
# Google Cloud / Vertex AI (Gemini diagnosis & eval judges — ADC, not API keys)
# =============================================================================
GOOGLE_CLOUD_PROJECT=<your-gcp-project>
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# Optional legacy aliases (used when GOOGLE_CLOUD_* is unset)
# VERTEX_PROJECT_ID=<your-gcp-project>
# VERTEX_LOCATION=global

# Gemini / ADK model override
AGENTGATE_GEMINI_MODEL=gemini-flash-latest
# ADK_MODEL=gemini-flash-latest

# =============================================================================
# Arize Phoenix (space-scoped collector URL — keep /s/<your-space>/ in path)
# =============================================================================
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/<your-space>/v1/traces
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/<your-space>
PHOENIX_API_KEY=<your-phoenix-api-key>
PHOENIX_PROJECT_NAME=<your-phoenix-project>

# Optional Phoenix aliases
# PHOENIX_PROJECT=<your-phoenix-project>
# PHOENIX_HOST=https://app.phoenix.arize.com/s/<your-space>

# =============================================================================
# AgentGate runtime (optional — defaults work for local Reference Ops demo)
# =============================================================================
# AGENTGATE_AGENT_PACK=configs/agents/stability_ops
# AGENTGATE_PHOENIX_PROJECT=<your-phoenix-project>
# AGENTGATE_MAX_DANGEROUS_TRACES=25
# AGENTGATE_PULL_REVIEWED_SAFE_TRACES=false
# AGENTGATE_CANDIDATE_VERSION=v2
# AGENTGATE_CANDIDATE_VERSIONS=v2,v2.1
# AGENTGATE_DIAGNOSIS_MODE=gemini
# AGENTGATE_LATEST_ARTIFACT_DIR=artifacts/release/latest
# AGENTGATE_PHOENIX_LOOKBACK_MINUTES=1440
# AGENTGATE_LOCAL_EVIDENCE_PATH=configs/agents/stability_ops/seed/v2_evidence.jsonl
# AGENTGATE_PUBLIC_URL=https://your-dashboard.example.com

# =============================================================================
# Phoenix eval automation (optional)
# =============================================================================
# AGENTGATE_EVAL_DATASET_NAME=<your-eval-dataset>
# AGENTGATE_EVAL_LLM_MODEL=gemini-flash-latest
# AGENTGATE_EVAL_LLM_COOLDOWN_SECONDS=2
# AGENTGATE_EVAL_LLM_MAX_RETRIES=5
# AGENTGATE_EVAL_LLM_RETRY_BASE_SECONDS=8
# AGENTGATE_EVAL_ANNOTATION_COOLDOWN_SECONDS=1
# AGENTGATE_EVAL_LOCAL_SUMMARY_FALLBACK=false

# =============================================================================
# Cloud Run deploy (shell convenience for gcloud — not read by AgentGate Python)
# =============================================================================
# PROJECT_ID=<your-gcp-project>
# REGION=us-central1

# =============================================================================
# Maintainer scripts (optional)
# =============================================================================
# AGENTGATE_UI_AUDIT_BASE_URL=http://127.0.0.1:8000
# AGENTGATE_UI_AUDIT_SKIP_RUN_COMPLETE=false
